{
  "entities": {
    "Team": {
      "title": "Team",
      "description": "A team participating in the tournament.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "city": { "type": "string" },
        "logo": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "city", "logo", "status"]
    },
    "Match": {
      "title": "Match",
      "description": "A match in the tournament.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teamA": { "$ref": "#/entities/Team" },
        "teamB": { "$ref": "#/entities/Team" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string" },
        "score": {
          "type": "object",
          "properties": {
            "setsA": { "type": "number" },
            "setsB": { "type": "number" }
          }
        }
      },
      "required": ["id", "teamA", "teamB", "date", "time", "status", "score"]
    },
    "Post": {
      "title": "Post",
      "description": "A post in the fan feed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "author": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string" },
        "likes": { "type": "number" }
      },
      "required": ["id", "author", "content", "timestamp", "likes"]
    },
    "TicketBooking": {
      "title": "TicketBooking",
      "description": "A booking made by a fan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "matchId": { "type": "string" },
        "seatIds": { "type": "array" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "matchId", "seatIds", "userId", "timestamp"]
    }
  },
  "firestore": {
    "teams": {
      "schema": "#/entities/Team",
      "description": "List of active teams."
    },
    "matches": {
      "schema": "#/entities/Match",
      "description": "Matches played or scheduled."
    },
    "posts": {
      "schema": "#/entities/Post",
      "description": "User posts in the fan feed."
    },
    "bookings": {
      "schema": "#/entities/TicketBooking",
      "description": "Bookings for matches."
    }
  }
}
