rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic Auth Check
    function isSignedIn() { return request.auth != null; }
    
    match /{document=**} {
      allow read, write: if false; // Default deny
    }

    // Teams: Authenticated users can read and write to sync globally
    match /teams/{teamId} {
      allow read: if true; // Public can read team data
      allow create, update: if isSignedIn(); // Any authenticated user can update for demo purposes
    }

    // Matches
    match /matches/{matchId} {
      allow read: if true;
      allow create, update: if isSignedIn();
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid; // Read own
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Allow updates to paymentstatus etc if it's the owner (for demo)
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
    }

    // Fan Feed Posts
    match /posts/{postId} {
      allow read: if true; // Public posts
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn(); // Allow liking (any user can like)
    }
  }
}
